# Copy this file to .env and edit it.
# Windows PowerShell:
#   Copy-Item .env.example .env
#   notepad .env

PORT=8765

# mock = no network/API key required. openai = OpenAI or OpenAI-compatible endpoint. anthropic = Anthropic Messages API.
LLM_PROVIDER=mock
LLM_THINKING_LEVEL=off

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Runtime behavior
LLM_TIMEOUT_MS=45000
MAX_SESSION_MESSAGES=10
MAX_HTML_CHARS=16000

# Keep false for the VibeOS-style hallucinated demo. This project does not execute local shell commands.
VIBEOS_ALLOW_LOCAL_TOOLS=false
